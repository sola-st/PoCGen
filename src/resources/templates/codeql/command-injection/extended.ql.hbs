private predicate isCommonBuiltinMethodName(string name) {
  exists(ExternalInstanceMemberDecl member |
    member.getBaseName() in ["Object", "Array", "String"] and
    name = member.getName()
  )
}

class BuiltinInvokeNode extends DataFlow::InvokeNode {
  BuiltinInvokeNode() {
    exists(GlobalProperties gp |
      this.(DataFlow::CallNode).getReceiver().accessesGlobal(gp) or
      this.(DataFlow::NewNode).accessesGlobal(gp) or
      this.getCalleeNode().accessesGlobal(gp)
    )
    or
    this.asExpr() instanceof Import
  }
}

class UnresolvedCallNode extends DataFlow::InvokeNode {
  UnresolvedCallNode() { not exists(this.getACallee()) }
}

// todo: node modules
class ExternalAPICall extends UnresolvedCallNode {
  //DataFlow::InvokeNode {
  ExternalAPICall() {
    not this instanceof BuiltinInvokeNode and
    not isCommonBuiltinMethodName(this.(DataFlow::CallNode).getCalleeName()) and
    (
      this instanceof UnresolvedCallNode or
      none()
      // this instanceof ExternalApiUsedWithUntrustedData::Sink
    )
  }
}

class ExternalSink extends DataFlow::Node {
  ExternalSink() { exists(ExternalAPICall c | c.getAnArgument() = this) }
}

predicate hasLocation(Function f) {
  {{FUNCTION_PREDICATE}}
}

module Config implements DataFlow::ConfigSig {

  DataFlow::FlowFeature getAFeature() { result instanceof DataFlow::FeatureHasSourceCallContext }

  predicate isSource(DataFlow::Node source) {
    exists(Function f | hasLocation(f) and source.asExpr().getEnclosingFunction() = f | {{SOURCE_PREDICATE}})
  }

  predicate isSink(DataFlow::Node sink) {

   sink instanceof ExternalSink

   /* exists(CallExpr ca | ca.getAnArgument() = sink.asExpr()) and
            (
              sink instanceof ExternalApiUsedWithUntrustedData::Sink
              or
              exists(CallExpr ca | ca.getAnArgument() = sink.asExpr() |
                not exists(FunctionDeclStmt v | ca.getReceiver() = v.getVariable().getAnAccess())

                not exists(DeclStmt v |
                  ca.getReceiver() = v.getADecl().getBindingPattern().getAVariable().getAnAccess()
                  or
                  ca.getCallee() = v.getADecl().getBindingPattern().getAVariable().getAnAccess()
                  or
                  ca.getReceiver() = v.getADecl().getBindingPattern().getAVariable().getAReference()
                )

              )

            )

            */
  }

}

module Flow = TaintTracking::Global<Config>;

import Flow::PathGraph

from Flow::PathNode source, Flow::PathNode sink
where Flow::flowPath(source, sink)
select sink.getNode(), source, sink, ""
